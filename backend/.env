# ==========================================
# Django 基础配置
# ==========================================
DEBUG=1
DJANGO_SECRET_KEY=your-secret-key-please-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# 跨域（前端开发地址）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==========================================
# 数据库配置
# ==========================================
# 开发阶段直接注释掉 PG 配置，Django 会默认使用 sqlite3
# PG_DATABASE=ai_soulmate
# PG_USER=postgres
# PG_PASSWORD=your-password
# PG_HOST=127.0.0.1
# PG_PORT=5432

# ==========================================
# 大模型配置 (Ollama 本地部署)
# ==========================================
# 保持您原有的配置，完美适配 LangChain 的 OpenAI 兼容接口
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
LLM_MODEL=qwen2.5:14b



CHROMA_PERSIST_DIR=./chroma_db

# ==========================================
# WebSocket 缓存层 (Redis)
# ==========================================
# 启用本地的 redis:latest 容器，映射到 6379 端口
REDIS_URL=redis://127.0.0.1:6380/0

# ==========================================
# 语音模块 (可选)
# ==========================================
# 语音识别：暂无配置则默认不开启或使用系统设定
# WHISPER_MODEL=base

# 语音合成：ElevenLabs 或其他
# ELEVENLABS_API_KEY=xxx
# ELEVENLABS_VOICE_ID=xxx

QWEATHER_API_KEY=your_api_key

TIANAPI_KEY=your_api_key